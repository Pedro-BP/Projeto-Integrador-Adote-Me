{
  "_type": "export",
  "__export_format": 4,
  "__export_date": "2026-07-10T00:00:00.000Z",
  "__export_source": "adote-me.manual-export",
  "resources": [
    {
      "_id": "wrk_adoteme",
      "_type": "workspace",
      "parentId": null,
      "name": "Adote-Me API",
      "description": "Coleção de requests da API do Adote-Me (Backend/src/routes.php)"
    },
    {
      "_id": "env_base",
      "_type": "environment",
      "parentId": "wrk_adoteme",
      "name": "Local",
      "data": {
        "base_url": "http://localhost:8000",
        "token": "",
        "pet_id": "",
        "postagem_id": ""
      }
    },
    {
      "_id": "fld_auth",
      "_type": "request_group",
      "parentId": "wrk_adoteme",
      "name": "Autenticação"
    },
    {
      "_id": "req_cadastrar_usuario",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Cadastrar usuário",
      "method": "POST",
      "url": "{{ _.base_url }}/usuarios",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"nome\": \"Usuário Teste\",\n  \"email\": \"teste@example.com\",\n  \"senha\": \"senha123\"\n}"
      }
    },
    {
      "_id": "req_login",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Login",
      "method": "POST",
      "url": "{{ _.base_url }}/login",
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"email\": \"teste@example.com\",\n  \"senha\": \"senha123\"\n}"
      },
      "description": "Copie o \"token\" da resposta pro environment (\"token\") pra usar nas rotas protegidas."
    },
    {
      "_id": "req_listar_usuarios",
      "_type": "request",
      "parentId": "fld_auth",
      "name": "Listar usuários (admin)",
      "method": "GET",
      "url": "{{ _.base_url }}/usuarios",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ _.token }}" }]
    },
    {
      "_id": "fld_pets",
      "_type": "request_group",
      "parentId": "wrk_adoteme",
      "name": "Pets"
    },
    {
      "_id": "req_listar_pets",
      "_type": "request",
      "parentId": "fld_pets",
      "name": "Listar pets",
      "method": "GET",
      "url": "{{ _.base_url }}/pets"
    },
    {
      "_id": "req_listar_pets_filtro",
      "_type": "request",
      "parentId": "fld_pets",
      "name": "Listar pets (filtro tipo/porte)",
      "method": "GET",
      "url": "{{ _.base_url }}/pets",
      "parameters": [
        { "name": "tipo", "value": "cachorro" },
        { "name": "porte", "value": "medio" }
      ]
    },
    {
      "_id": "req_detalhe_pet",
      "_type": "request",
      "parentId": "fld_pets",
      "name": "Detalhe de um pet",
      "method": "GET",
      "url": "{{ _.base_url }}/pets/{{ _.pet_id }}"
    },
    {
      "_id": "req_criar_pet",
      "_type": "request",
      "parentId": "fld_pets",
      "name": "Cadastrar pet (admin)",
      "method": "POST",
      "url": "{{ _.base_url }}/pets",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.token }}" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"nome\": \"Thor\",\n  \"tipo\": \"cachorro\",\n  \"porte\": \"medio\",\n  \"idade\": \"2 anos\",\n  \"cidade\": \"Tramandaí\",\n  \"bairro\": \"Centro\",\n  \"foto_url\": \"\",\n  \"historia\": \"Resgatado com uma pata machucada, hoje está ótimo.\",\n  \"numero\": \"(51) 99101-3434\",\n  \"email\": \"adotemetramandai@gmail.com\"\n}"
      },
      "description": "Copie o \"id\" da resposta pro environment (\"pet_id\") pra usar nas próximas rotas."
    },
    {
      "_id": "req_atualizar_pet",
      "_type": "request",
      "parentId": "fld_pets",
      "name": "Atualizar pet (admin)",
      "method": "PUT",
      "url": "{{ _.base_url }}/pets/{{ _.pet_id }}",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.token }}" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"status\": \"adotado\"\n}"
      },
      "description": "Só os campos enviados são alterados — troque o body pra editar outros campos (nome, idade, etc)."
    },
    {
      "_id": "req_excluir_pet",
      "_type": "request",
      "parentId": "fld_pets",
      "name": "Excluir pet (admin)",
      "method": "DELETE",
      "url": "{{ _.base_url }}/pets/{{ _.pet_id }}",
      "headers": [{ "name": "Authorization", "value": "Bearer {{ _.token }}" }],
      "description": "Retorna 409 se houver postagens vinculadas a esse pet."
    },
    {
      "_id": "fld_postagens",
      "_type": "request_group",
      "parentId": "wrk_adoteme",
      "name": "Postagens"
    },
    {
      "_id": "req_listar_postagens",
      "_type": "request",
      "parentId": "fld_postagens",
      "name": "Listar postagens",
      "method": "GET",
      "url": "{{ _.base_url }}/postagens"
    },
    {
      "_id": "req_detalhe_postagem",
      "_type": "request",
      "parentId": "fld_postagens",
      "name": "Detalhe de uma postagem",
      "method": "GET",
      "url": "{{ _.base_url }}/postagens/{{ _.postagem_id }}"
    },
    {
      "_id": "req_criar_postagem",
      "_type": "request",
      "parentId": "fld_postagens",
      "name": "Criar postagem (logado)",
      "method": "POST",
      "url": "{{ _.base_url }}/postagens",
      "headers": [
        { "name": "Content-Type", "value": "application/json" },
        { "name": "Authorization", "value": "Bearer {{ _.token }}" }
      ],
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"pet_id\": \"{{ _.pet_id }}\",\n  \"foto_url\": \"\",\n  \"relato\": \"Já faz um mês que ele chegou e está super adaptado.\"\n}"
      },
      "description": "Exige apenas estar logado — qualquer perfil (admin ou usuario). Copie o \"id\" da resposta pro environment (\"postagem_id\")."
    },
    {
      "_id": "req_curtir_postagem",
      "_type": "request",
      "parentId": "fld_postagens",
      "name": "Curtir postagem",
      "method": "POST",
      "url": "{{ _.base_url }}/postagens/{{ _.postagem_id }}/curtir",
      "description": "Pública, sem login. Só incrementa — não existe \"descurtir\"."
    }
  ]
}
